# Vercel Blob storage (image + metadata uploads, coin index)
BLOB_READ_WRITE_TOKEN=your_vercel_blob_rw_token

# Solana RPC (server-side sends + fallback)
RPC_URL=https://mainnet.helius-rpc.com/?api-key=your_helius_key
# Solana RPC (browser: quotes, curve state, swap sends)
NEXT_PUBLIC_RPC_URL=https://mainnet.helius-rpc.com/?api-key=your_helius_key

# Multi-curve launchpad program (curve-launchpad fork)
NEXT_PUBLIC_CURVE_PROGRAM_ID=G2LGhLggpxLknXSkEhWqmukeS1m6NJXYqhaDHrV6JejZ
# Wallet receiving the platform half of the 50/50 trade fee
NEXT_PUBLIC_PLATFORM_FEE_WALLET=your_platform_fee_wallet

# Jito block engine for atomic launch bundles (optional; RPC fallback used otherwise)
JITO_BLOCK_ENGINE_URL=https://mainnet.block-engine.jito.wtf/api/v1/bundles

# Jupiter swap API for external routing legs
NEXT_PUBLIC_JUPITER_API=https://lite-api.jup.ag/swap/v1
